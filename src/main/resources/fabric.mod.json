{
  "schemaVersion": 1,
  "id": "chibify",
  "version": "${version}",
  "name": "Chibify",
  "description": "Render minecraft players as cute chibis",
  "authors": ["nxyi"],
  "contact": {
    "github": "https://github.com/Nxyi/Chibify",
    "modrinth": "https://modrinth.com/mod/chibify"
  },
  "license": "All-Rights-Reserved",
  "icon": "assets/icon.png",
  "environment": "client",
  "entrypoints": {
    "modmenu": ["net.chibify.chibify.config.ModMenuIntegration"],
    "client": [
      "net.chibify.chibify.client.ChibifyClient"
    ],
    "main": [
      "net.chibify.chibify.Chibify"
    ]
  },
  "mixins": [
    "chibify.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}",
    "yet_another_config_lib_v3": "${yacl_version}"
  }
}
